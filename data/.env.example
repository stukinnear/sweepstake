# Copy this file to .env (or .env.local for local overrides) and fill in your values.
# Priority (highest to lowest): env vars > .env.local > .env > settings.yaml

# --- Server ---
PORT=8888
DEBUG=false
SECRET_KEY=change-me-to-a-long-random-string
ROOT_PATH=
HTTPS_AUTH_ONLY=true

# --- Database ---
# If not set, defaults to SQLite at data/sweepstake.db (PostgreSQL recommended for production).
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/sweepstake
DB_POOL_SIZE=5
DB_MAX_OVERFLOW=10
DB_POOL_RECYCLE=3600

# --- Auth tokens ---
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7
PASSWORD_RESET_EXPIRE_MINUTES=30

# --- CORS & frontend ---
# JSON array or comma-separated list
HOSTS=["http://localhost:3000","http://localhost:5173"]
MAIN_HOST=http://localhost:3000

# --- Email (SMTP) ---
EMAIL_HOST=
EMAIL_PORT=587
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
EMAIL_FROM=noreply@example.com
EMAIL_USE_TLS=true
EMAIL_USE_SSL=false

# --- External APIs ---
FOOTBALL_DATA_ORG_API_KEY=

# --- Error monitoring ---
# Set to your Sentry DSN to enable Sentry monitoring (backend + frontend).
# Leave empty to disable.
SENTRY_DSN=

# --- Dev / testing ---
LOAD_TEST_DATA=false
