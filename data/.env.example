# Copy this file to .env (or .env.local for local overrides) and fill in your values.
# Priority (highest to lowest): env vars > .env.local > .env > settings.yaml

# --- Server ---
SERVER_PORT=8888
SERVER_DEBUG=false
SERVER_SECRET_KEY=change-me-to-a-long-random-string
SERVER_ROOT_PATH=
SERVER_HTTPS_AUTH_ONLY=true

# --- Database ---
SERVER_DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/sweepstake
SERVER_DB_POOL_SIZE=5
SERVER_DB_MAX_OVERFLOW=10
SERVER_DB_POOL_RECYCLE=3600

# --- Auth tokens ---
SERVER_ACCESS_TOKEN_EXPIRE_MINUTES=30
SERVER_REFRESH_TOKEN_EXPIRE_DAYS=7
SERVER_PASSWORD_RESET_EXPIRE_MINUTES=30

# --- CORS & frontend ---
# JSON array or comma-separated list
SERVER_CORS_ORIGINS=["http://localhost:3000","http://localhost:5173"]
SERVER_FRONTEND_URL=http://localhost:3000

# --- Email (SMTP) ---
SERVER_SMTP_HOST=
SERVER_SMTP_PORT=587
SERVER_SMTP_USERNAME=
SERVER_SMTP_PASSWORD=
SERVER_SMTP_FROM_EMAIL=noreply@example.com

# --- External APIs ---
# No SERVER_ prefix for this one
FOOTBALL_DATA_ORG_API_KEY=

# --- Error monitoring ---
# Set to your Sentry DSN to enable Sentry monitoring (backend + frontend).
# Accepts SENTRY_DSN or SERVER_SENTRY_DSN. Leave empty to disable.
SENTRY_DSN=

# --- Dev / testing ---
SERVER_LOAD_TEST_DATA=false
