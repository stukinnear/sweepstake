{
    "version": "0.2.0",
    "configurations": [

        {
            "name": "Setup Dev Environment (Mac)",
            "type": "node",
            "request": "launch",
            "runtimeExecutable": "/bin/bash",
            "runtimeArgs": [
                "${workspaceFolder}/.vscode/setup-dev.sh",
                "${workspaceFolder}"
            ],
            "console": "integratedTerminal"
        },

        {
            "name": "Run All Tests",
            "type": "debugpy",
            "request": "launch",
            "python": "${workspaceFolder}/backend/.venv/bin/python",
            "module": "pytest",
            "args": ["tests/", "-v", "--no-header"],
            "cwd": "${workspaceFolder}/backend",
            "console": "integratedTerminal",
            "justMyCode": true,
            "env": {
                "PYTHONPATH": "${workspaceFolder}/backend"
            }
        },

        {
            "name": "Run FastAPI Backend",
            "type": "debugpy",
            "request": "launch",
            "python": "${workspaceFolder}/backend/.venv/bin/python",
            "module": "uvicorn",
            "args": [
                "src.main:app",
                "--reload",
                "--port", "8888"
            ],
            "cwd": "${workspaceFolder}/backend",
            "env": {
                "PYTHONPATH": "${workspaceFolder}/backend",
                "HTTPS_AUTH_ONLY": "false",
                "DATABASE_URL": "postgresql+asyncpg://postgres:postgres@localhost:5432/sweepstake",
            },
            "jinja": true,
            "preLaunchTask": "start-postgres",
            "postDebugTask": "stop-postgres"
        },

        {
            "name": "Run FastAPI Backend (with Test Data)",
            "type": "debugpy",
            "request": "launch",
            "python": "${workspaceFolder}/backend/.venv/bin/python",
            "module": "uvicorn",
            "args": [
                "src.main:app",
                "--reload",
                "--port", "8888"
            ],
            "cwd": "${workspaceFolder}/backend",
            "env": {
                "PYTHONPATH": "${workspaceFolder}/backend",
                "LOAD_TEST_DATA": "true",
                "HTTPS_AUTH_ONLY": "false",
                "DATABASE_URL": "postgresql+asyncpg://postgres:postgres@localhost:5432/sweepstake",
            },
            "jinja": true,
            "preLaunchTask": "start-postgres",
            "postDebugTask": "stop-postgres"
        },

        {
            "name": "Run React Frontend",
            "type": "node",
            "request": "launch",
            "runtimeExecutable": "npm",
            "runtimeArgs": ["run", "dev"],
            "cwd": "${workspaceFolder}/frontend",
            "console": "integratedTerminal",
            "serverReadyAction": {
                "pattern": "Local:.*http://localhost:(\\d+)",
                "uriFormat": "http://localhost:%s",
                "action": "openExternally"
            }
        },

        {
            "name": "Run update_tournaments task",
            "type": "debugpy",
            "request": "launch",
            "python": "${workspaceFolder}/backend/.venv/bin/python",
            "program": "${workspaceFolder}/backend/src/api_football_data_org/update_tournament.py",
            "args": ["2000"],
            "cwd": "${workspaceFolder}/backend",
            "env": {
                "PYTHONPATH": "${workspaceFolder}/backend",
                "DATABASE_URL": "postgresql+asyncpg://postgres:postgres@localhost:5432/sweepstake"
            },
            "jinja": true,
            "preLaunchTask": "start-postgres",
            "postDebugTask": "stop-postgres"
        },

        {
            "name": "Build & Run Docker Container w/ SQLite (Demo Mode)",
            "type": "node",
            "request": "launch",
            "runtimeExecutable": "/bin/bash",
            "runtimeArgs": [
                "-c",
                "docker build -t sweepstake-demo . && docker run --rm -p 80:80 -e DEMO_MODE=true --name sweepstake-demo sweepstake-demo"
            ],
            "cwd": "${workspaceFolder}",
            "console": "integratedTerminal"
        },

        {
            "name": "Build & Run Docker Container w/ Postgres (Prod Mode)",
            "type": "node",       // or python, go, etc.
            "request": "attach",
            "port": 9229,
            "preLaunchTask": "Docker Compose Up (Build)",
        },

    ]
}